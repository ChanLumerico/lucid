\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/lucid-theorems}[2026/05/23 Lucid theorem environments]

\RequirePackage{amsthm}
\RequirePackage{thmtools}

% --- Bold-head italic-body (theorems, lemmas, propositions) ---
\declaretheoremstyle[
  headfont=\bfseries\sffamily,
  bodyfont=\itshape,
  postheadspace=0.5em,
  spaceabove=12pt,
  spacebelow=6pt,
]{lucid.thmbase}

\declaretheorem[style=lucid.thmbase,within=chapter]{theorem}
\declaretheorem[style=lucid.thmbase,sibling=theorem]{lemma}
\declaretheorem[style=lucid.thmbase,sibling=theorem]{proposition}
\declaretheorem[style=lucid.thmbase,sibling=theorem]{corollary}

% --- Bold-head upright-body (definitions, examples, remarks) ---
\declaretheoremstyle[
  headfont=\bfseries\sffamily,
  bodyfont=\upshape,
  postheadspace=0.5em,
  spaceabove=12pt,
  spacebelow=6pt,
]{lucid.defstyle}

\declaretheorem[style=lucid.defstyle,within=chapter]{definition}
\declaretheorem[style=lucid.defstyle,sibling=theorem]{example}
\declaretheorem[style=lucid.defstyle,sibling=theorem]{remark}
\declaretheorem[style=lucid.defstyle,sibling=theorem]{notation}
\declaretheorem[style=lucid.defstyle,sibling=theorem]{assumption}

% --- Bold-head upright sans-serif (algorithms, contracts) ---
\declaretheoremstyle[
  headfont=\bfseries\sffamily,
  bodyfont=\upshape\sffamily,
  postheadspace=0.5em,
  spaceabove=12pt,
  spacebelow=6pt,
]{lucid.algstyle}

\declaretheorem[style=lucid.algstyle,within=chapter]{contract}

% --- QED symbol ---
\renewcommand{\qedsymbol}{$\blacksquare$}

\endinput
