% --- Cross references (load late) ---
\RequirePackage{hyperref}
\hypersetup{
  colorlinks=true,
  linkcolor=lucid.accent.dark,
  citecolor=lucid.accent.dark,
  urlcolor=lucid.accent.dark,
  pdftitle={Lucid: An Apple Silicon Native Machine Learning Framework},
  pdfauthor={Chan Lee},
  pdfsubject={Machine learning framework, Apple silicon, MLX, Accelerate},
  pdfkeywords={Lucid, MLX, Apple silicon, autograd, deep learning},
  bookmarksnumbered=true,
  bookmarksopen=true,
  bookmarksopenlevel=1,
}
\RequirePackage[capitalize,noabbrev]{cleveref}

% --- hyperref safety: handle \_ in section/subsection titles ---
% When a title contains `\_` (escaped underscore), hyperref tries to
% build a PDF bookmark using its own catcode regime. The escape can
% destabilise group balance and bleed monospace font through the
% rest of the chapter. Tell hyperref to render `\_` as a literal
% underscore in PDF strings; the TeX-side rendering is unaffected.
\pdfstringdefDisableCommands{%
  \let\_\textunderscore
  \let\textbackslash\empty
}

% --- Index ---
\RequirePackage{imakeidx}
\makeindex[intoc,title={Index}]

% --- Todo notes ---
% Disabled by default --- the 35 unwritten chapter stubs all carry
% \todo[inline]{...} markers that would otherwise show as yellow
% boxes in the PDF and as warning squiggles in IDEs.
% To re-enable during drafting, replace `disable` with the prior
% option set: colorinlistoftodos,prependcaption,textsize=small.
\RequirePackage[disable]{todonotes}

% =====================================================================
% Page layout (memoir)
% A4 paper, generous but utilised typeblock (~720pt height by ~450pt
% width). Margins are 2.7 cm top / 2.5 cm side --- enough for binding
% but not so much that each page only holds half a screen of text.
% =====================================================================
\setstocksize{297mm}{210mm}
\settrimmedsize{297mm}{210mm}{*}
\setlength{\trimtop}{0pt}
\setlength{\trimedge}{\stockwidth}
\addtolength{\trimedge}{-\paperwidth}
\settypeblocksize{720pt}{450pt}{*}
\setulmargins{2.7cm}{*}{*}
% Symmetric L/R margins (was 1.2 inner:outer ratio, which makes
% even and odd pages have visibly different left edges --- looks
% like odd pages are indented).
\setlrmargins{*}{*}{1.0}
\setheaderspaces{*}{1.5\baselineskip}{*}
\setheadfoot{\onelineskip}{2\onelineskip}
\checkandfixthelayout

% --- Page break tolerance ---
% Default \tolerance = 200; \emergencystretch = 0pt. Raising them
% lets LaTeX break paragraphs and pages a bit more loosely instead of
% leaving large gaps before unbreakable environments.
\tolerance=3000
\emergencystretch=4em
\hbadness=2000
\hfuzz=2pt
% Discourage (but do not forbid) widows and orphans.
\widowpenalty=150
\clubpenalty=150

% =====================================================================
% Chapter / part style
% =====================================================================
% --- Custom chapter style ---
% memoir's `veelo' style places the chapter number on a dark band that
% extends past the page edge, which clips two-digit numbers (Ch10+).
% We define a safe in-textblock style instead: small-caps CHAPTER
% label, large chapter number, accent rule, then title on its own line.
\makechapterstyle{lucidchap}{%
  \renewcommand*{\chapterheadstart}{\vspace*{2\beforechapskip}}
  \renewcommand*{\chapnamefont}{%
    \normalfont\Large\sffamily\scshape\color{lucid.muted}}
  \renewcommand*{\chapnumfont}{%
    \normalfont\fontsize{60pt}{60pt}\selectfont\sffamily\bfseries
    \color{lucid.accent.dark}}
  \renewcommand*{\chaptitlefont}{%
    \normalfont\Huge\sffamily\bfseries}
  \renewcommand*{\printchaptername}{\noindent\chapnamefont \@chapapp}
  \renewcommand*{\chapternamenum}{\quad}
  \renewcommand*{\printchapternum}{\chapnumfont\thechapter}
  \renewcommand*{\afterchapternum}{%
    \par\vspace{0.4em}%
    \noindent{\color{lucid.accent.dark}\rule{\textwidth}{1.5pt}}%
    \par\vspace{0.8em}}
  \renewcommand*{\printchaptertitle}[1]{%
    \noindent\chaptitlefont ##1\par}
}
\chapterstyle{lucidchap}
\setsecnumdepth{subsubsection}
\settocdepth{subsection}
\maxtocdepth{subsection}

\renewcommand{\partnamefont}{\normalfont\Large\sffamily\bfseries}
\renewcommand{\partnumfont}{\normalfont\Huge\sffamily\bfseries}
\renewcommand{\parttitlefont}{\normalfont\Huge\sffamily\bfseries}

