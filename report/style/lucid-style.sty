% --- Units shim ---
% Lightweight \SI{value}{unit} since we don't pull in siunitx.
% Provides only the milli- and micro-second / Hertz / byte / FLOP units
% used in this report; expand as needed.
\providecommand{\SI}[2]{#1\,#2}
\providecommand{\milli}{m}
\providecommand{\micro}{\textmu}
\providecommand{\second}{s}
\providecommand{\hertz}{Hz}
\providecommand{\byte}{B}

% --- Inline code ---
% Note: inside `\code{...}` the `_`, `&`, `#`, `$`, `%`, `~` characters
% must be backslash-escaped (e.g. `\code{cblas\_sgemm}`). For verbatim
% inline code use \lstinline instead.
\newcommand{\code}[1]{\texttt{\small #1}}
\newcommand{\pkg}[1]{\textsf{\small #1}}

% --- Cross-ref helpers ---
\newcommand{\chref}[1]{Chapter~\ref{#1}}
\newcommand{\secref}[1]{Section~\ref{#1}}
\newcommand{\partref}[1]{Part~\ref{#1}}
\newcommand{\figref}[1]{Figure~\ref{#1}}
\newcommand{\tabref}[1]{Table~\ref{#1}}
\newcommand{\appref}[1]{Appendix~\ref{#1}}

