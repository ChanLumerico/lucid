\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/lucid-listings}[2026/05/23 Lucid code listings]

\RequirePackage{listings}
\RequirePackage{style/lucid-colors}

\lstdefinestyle{lucid}{
  basicstyle=\ttfamily\small,
  keywordstyle=\color{lucid.code.kw}\bfseries,
  stringstyle=\color{lucid.code.str},
  commentstyle=\color{lucid.code.cm}\itshape,
  numberstyle=\tiny\color{lucid.code.cm},
  identifierstyle=\color{lucid.code.ident},
  backgroundcolor=\color{lucid.code.bg},
  frame=single,
  framesep=6pt,
  rulecolor=\color{lucid.rule},
  framerule=0.4pt,
  xleftmargin=10pt,
  xrightmargin=4pt,
  numbers=left,
  stepnumber=1,
  numbersep=10pt,
  showspaces=false,
  showtabs=false,
  showstringspaces=false,
  tabsize=4,
  breaklines=true,
  breakatwhitespace=true,
  captionpos=b,
  abovecaptionskip=8pt,
  belowcaptionskip=4pt,
}

\lstset{style=lucid}

% --- Lucid Python flavor (extra keywords for the framework surface) ---
\lstdefinelanguage{LucidPython}[]{Python}{
  morekeywords={
    Tensor, Module, Parameter,
    nn, optim, autograd, linalg, fft, einops, amp, profiler,
    compile, no_grad, enable_grad, inference_mode,
    vmap, grad, jvp, vjp, jacrev, jacfwd, hessian,
    requires_grad, backward, dtype, device,
    float16, float32, float64, bfloat16, int32, int64, bool,
    cpu, metal,
  },
  morekeywords=[2]{
    self, cls, None, True, False,
  },
  sensitive=true,
}

% --- C++ engine listings ---
\lstdefinestyle{lucidcpp}{
  style=lucid,
  language=C++,
  morekeywords={
    TensorImpl, Storage, Allocator, Dtype, Device,
    AutogradMeta, Node, Engine, Function,
    LucidError, BackendBase, MlxBackend, AccelerateBackend,
    UnaryKernel, BinaryKernel, ReduceKernel,
  },
}

\endinput
