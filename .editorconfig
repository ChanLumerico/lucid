# Editor consistency for the Lucid repo. Honored by VS Code, JetBrains, vim,
# emacs, Zed, and most modern editors out of the box.

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{cpp,hpp,h,cc,cxx,c}]
indent_size = 4
max_line_length = 100

[*.{json,yaml,yml,toml}]
indent_size = 2

[*.md]
# Markdown: don't trim trailing whitespace (it's a hard line break).
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
