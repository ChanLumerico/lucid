#!/usr/bin/env bash
# .githooks/pre-commit — Lucid pre-commit gate.
#
# Two checks, both blocking (the second is hard-fail):
#
#   1. H4 numpy guard.  ``tools/check_numpy_h4.py`` walks lucid/ and
#      flags any ``import numpy`` outside the six sanctioned bridge
#      files (CLAUDE.md §6.1 H4).  The 3.0.1 → 3.0.2 hotfix sequence
#      surfaced four unsanctioned leaks that had crept in silently;
#      this guard makes the same regression visible at commit time
#      rather than after a release ships.
#
#   2. LOC badge refresh.  Runs ``cloc lucid/`` and rewrites the
#      shield badge in README.md so it always matches the committed
#      source.  Re-stages README.md.  Soft-fails (warning only) when
#      cloc isn't installed.
#
# Skip individual checks:
#     LUCID_SKIP_H4_GUARD=1     skip the H4 scan
#     LUCID_SKIP_LOC_BADGE=1    skip the LOC badge refresh

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ── 1. H4 numpy guard ───────────────────────────────────────────────────────
# Hard-fail.  Run before LOC refresh so a violation aborts the commit
# without leaving a half-applied badge stage.
if [[ "${LUCID_SKIP_H4_GUARD:-0}" != "1" ]]; then
    if ! python3 "${REPO_ROOT}/tools/check_numpy_h4.py" --quiet; then
        echo "" >&2
        # Re-run non-quiet to show the violations for the developer.
        python3 "${REPO_ROOT}/tools/check_numpy_h4.py" >&2 || true
        echo "" >&2
        echo "  ❌  Pre-commit blocked.  Fix H4 violation above and re-stage." >&2
        echo "      Override (discouraged):  LUCID_SKIP_H4_GUARD=1 git commit ..." >&2
        exit 1
    fi
fi

# ── 2. LOC badge refresh ────────────────────────────────────────────────────
if [[ "${LUCID_SKIP_LOC_BADGE:-0}" == "1" ]]; then
    exit 0
fi

README="${REPO_ROOT}/README.md"

if ! command -v cloc &>/dev/null; then
    echo "  ⚠️  cloc not found — skipping LOC badge update (brew install cloc)" >&2
    exit 0
fi

LOC="$(cloc "${REPO_ROOT}/lucid" --quiet 2>/dev/null | awk '/^SUM:/{print $NF}')"

if [[ -z "$LOC" || "$LOC" == "0" ]]; then
    echo "  ⚠️  cloc returned no result — skipping LOC badge update" >&2
    exit 0
fi

NEW_BADGE="![Lines of Code](https://img.shields.io/badge/Lines%20of%20Code-${LOC}-purple)"

sed -i '' \
    "s|!\[Lines of Code\](https://img\.shields\.io/badge/Lines%20of%20Code-[^)]*)|${NEW_BADGE}|g" \
    "${README}"

git add "${README}"
