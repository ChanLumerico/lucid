#!/usr/bin/env bash
# .githooks/prepare-commit-msg — Lucid auto-CHANGELOG injection.
#
# Fires AFTER the commit message has been drafted (template, merge, message
# argument, etc.) but BEFORE the commit object is sealed.  Parses the staged
# commit message; if its subject matches a user-facing conventional-commit
# prefix (feat / fix / perf / refactor / revert / remove / deprec / sec) and
# CHANGELOG.md was *not* already modified in this commit, automatically calls
# ``tools/changelog.py propose --auto --message-file <msg>`` to inject an
# entry into the [Unreleased] section, then stages CHANGELOG.md so it lands
# in the same commit.
#
# Result: every conventional commit lands with a CHANGELOG entry — no human
# step required, no risk of [Unreleased] going stale.
#
# Opt-out for a single commit:
#     LUCID_SKIP_CHANGELOG_CHECK=1 git commit ...
# Or use --no-verify (discouraged).
#
# This hook is only active when ``core.hooksPath`` points at .githooks/, e.g.:
#     git config core.hooksPath .githooks

set -uo pipefail

MSG_FILE="${1:-}"
COMMIT_SOURCE="${2:-}"    # template | message | merge | squash | commit | "" (normal)
[[ -z "${MSG_FILE}" || ! -f "${MSG_FILE}" ]] && exit 0

# Honor explicit opt-out (mirrors commit-msg / post-commit).
if [[ "${LUCID_SKIP_CHANGELOG_CHECK:-0}" == "1" ]]; then
    exit 0
fi

# Skip merge / squash / amend-without-message system commits — they aren't
# user-authored conventional commits.
case "${COMMIT_SOURCE}" in
    merge | squash) exit 0 ;;
esac

# Read the first line (subject).
SUBJECT="$(head -n 1 "${MSG_FILE}")"

# Skip fixup / revert / merge subjects.
case "${SUBJECT}" in
    Merge\ * | merge\ * | fixup!\ * | squash!\ * | "Revert \""*) exit 0 ;;
esac

# Match conventional-commit prefixes that warrant a CHANGELOG entry.
USER_FACING_RE='^(feat|fix|perf|refactor|revert|remove|deprec|sec)(\([^)]*\))?!?:[[:space:]]'
if ! [[ "${SUBJECT}" =~ ${USER_FACING_RE} ]]; then
    exit 0
fi

# If CHANGELOG.md is already in the staged change, the developer is
# updating it manually — don't double-inject.
if git diff --cached --name-only | grep -qx "CHANGELOG.md"; then
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
CHANGELOG_TOOL="${REPO_ROOT}/tools/changelog.py"

if [[ ! -f "${CHANGELOG_TOOL}" ]]; then
    # Tool missing — silently skip (older checkouts).
    exit 0
fi

# Auto-inject the entry, parsing the staged commit message file (HEAD hasn't
# been updated yet at this point, so reading via `git log` would yield the
# *previous* commit).
if python3 "${CHANGELOG_TOOL}" propose --auto --message-file "${MSG_FILE}" 2>/dev/null; then
    git add "${REPO_ROOT}/CHANGELOG.md"
    echo "  📝  CHANGELOG.md auto-updated with this commit's subject ✓" >&2
fi

exit 0
