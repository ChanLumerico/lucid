#!/usr/bin/env bash
# .githooks/commit-msg — Lucid commit-convention + CHANGELOG hygiene.
#
# Two checks:
#   1. Commit-convention format (BLOCKING) — validates <type>(<scope>): <subject>
#      against CONTRIBUTING.md §6 via tools/check_commit_msg.py.
#   2. CHANGELOG hygiene (warn only) — a user-facing commit (feat/fix/perf/
#      refactor/revert/remove/deprecate/security) that doesn't touch CHANGELOG.md.
#
# Bypass:  LUCID_SKIP_COMMIT_CONVENTION=1  (format)
#          LUCID_SKIP_CHANGELOG_CHECK=1    (changelog warn)
#          git commit --no-verify          (both — discouraged; CI still checks)
#
# Activate hooks for this repo with:
#   ./tools/install_hooks.sh        (sets core.hooksPath = .githooks)

set -u

MSG_FILE="${1:-}"
[[ -z "${MSG_FILE}" || ! -f "${MSG_FILE}" ]] && exit 0

# ── 1. Commit-convention format check (BLOCKING) ────────────────────────────
REPO_ROOT_CM="$(git rev-parse --show-toplevel)"
CONVENTION_SCRIPT="${REPO_ROOT_CM}/tools/check_commit_msg.py"
if [[ "${LUCID_SKIP_COMMIT_CONVENTION:-0}" != "1" && -f "${CONVENTION_SCRIPT}" ]] \
    && command -v python3 &>/dev/null; then
    if ! python3 "${CONVENTION_SCRIPT}" --file "${MSG_FILE}" >&2; then
        echo "" >&2
        echo "  ❌  Commit blocked: subject violates the Lucid commit convention." >&2
        exit 1
    fi
fi

# ── 2. CHANGELOG hygiene (warn only) ────────────────────────────────────────
# Read the first line of the commit message (subject).
SUBJECT="$(head -n 1 "${MSG_FILE}")"

# Skip merge / fixup / revert system commits — they aren't user-authored.
case "${SUBJECT}" in
    Merge\ * | merge\ * | fixup!\ * | squash!\ * | "Revert \""*) exit 0 ;;
esac

# Honor explicit opt-out.
if [[ "${LUCID_SKIP_CHANGELOG_CHECK:-0}" == "1" ]]; then
    exit 0
fi

# Conventional-commit prefix detection (user-facing types only).
USER_FACING_RE='^(feat|fix|perf|refactor|revert|remove|deprecate|security)(\([^)]*\))?!?:[[:space:]]'
if ! [[ "${SUBJECT}" =~ ${USER_FACING_RE} ]]; then
    # Not a user-facing prefix → no CHANGELOG entry required.
    exit 0
fi

# Check whether the staged change touches CHANGELOG.md.
if git diff --cached --name-only | grep -qx "CHANGELOG.md"; then
    exit 0
fi

# Warn but don't block — the post-commit hook auto-folds an entry anyway.
cat <<EOF >&2

  ⚠️   CHANGELOG hygiene reminder
      ──────────────────────────
      Commit subject:  ${SUBJECT}
      This looks like a user-facing change (feat/fix/perf/...) but
      CHANGELOG.md was NOT updated.

      Add an entry now (recommended):
          python tools/changelog.py propose      # auto-suggest from this commit
          python tools/changelog.py add <category> "<message>"

      Categories: added | changed | deprecated | removed | fixed | security
                  performance | tooling | documentation

      Bypass for this single commit:
          LUCID_SKIP_CHANGELOG_CHECK=1 git commit ...

EOF

exit 0
