      "summary": "Configuration for Attention U-Net.",
      "extended": "Extends the standard U-Net architecture (Ronneberger et al., 2015) by\nadding soft attention gates on skip connections.  Each gate computes a\nspatial attention map from the skip feature and the gating signal from\nthe decoder, suppressing irrelevant activations before concatenation.",
      "parameters": [
        {
          "name": "num_classes",
          "annotation": "int",
          "description": "Number of output segmentation classes.",
          "default": "2"
        },
        {
          "name": "in_channels",
          "annotation": "int",
          "description": "Number of input image channels.",
          "default": "1"
        },
        {
          "name": "base_channels",
          "annotation": "int",
          "description": "Feature channels at the first encoder stage.\n           Doubles at each depth level.",
          "default": "64"
        },
        {
          "name": "depth",
          "annotation": "int",
          "description": "Number of encoder/decoder stages (excluding bottleneck).",
          "default": "4"
        },
        {
          "name": "bilinear",
          "annotation": "bool",
          "description": "If True, use bilinear upsampling; otherwise ConvTranspose2d.",
          "default": "False"
        }
      ],
      "returns": null,
      "raises": [],
      "examples": [],
      "notes": [
        "Encoder: depth × (2×Conv3x3-BN-ReLU + MaxPool2x2)\nBottleneck: 2×Conv3x3-BN-ReLU\nDecoder: depth × (Upsample/ConvTranspose + AttentionGate + Cat + 2×Conv3x3-BN-ReLU)\nHead: Conv1x1 → num_classes"
      ],
      "attributes": [],
      "warns": [],
      "see_also": []
    },
