      "summary": "Snapshot of allocator state at a single point in time.",
      "extended": "Wraps the engine's memory tracker so user code can correlate peak\nmemory usage with specific phases of training or inference. Combined\nwith `Profiler` events, this is sufficient to diagnose memory\nregressions and validate the effect of activation checkpointing.",
      "parameters": [
        {
          "name": "impl",
          "annotation": "object",
          "description": "Underlying engine `MemoryStats` handle.",
          "default": null
        }
      ],
      "returns": null,
      "raises": [],
      "examples": [
        ">>> import lucid\n>>> with lucid.profiler.profile() as prof:\n...     _ = lucid.randn(1024, 1024)\n>>> stats = prof.memory_stats()\n>>> stats and stats.peak_bytes"
      ],
      "notes": [
        "Reported quantities are byte counts. The ratio\n$\\text{peak} / \\text{current}$ is a coarse indicator of\nfragmentation overhead."
      ],
      "attributes": [],
      "warns": [],
      "see_also": []
