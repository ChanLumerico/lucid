      ],
      "summary": "A single recorded operation event captured by the profiler.",
      "extended": "Each `OpEvent` corresponds to one C++ engine op invocation: name,\nwall-clock duration, output tensor shape, an FLOP estimate, and the\nnet memory delta. Profilers expose lists of these events so that\nper-op cost can be aggregated, exported, and visualised.",
      "parameters": [
        {
          "name": "impl",
          "annotation": "object",
          "description": "Underlying engine `OpEvent` handle returned from the C++\nprofiler.",
          "default": null
        }
      ],
      "returns": null,
      "raises": [],
      "examples": [
        ">>> import lucid\n>>> with lucid.profiler.profile() as prof:\n...     y = lucid.randn(64, 64) @ lucid.randn(64, 64)\n>>> for ev in prof.events():\n...     print(ev.name, ev.time_us)"
      ],
      "notes": [
        "Durations are reported in nanoseconds at the source; helper\nproperties expose the same value in microseconds and milliseconds\nfor convenience."
      ],
      "attributes": [],
      "warns": [],
      "see_also": []
    },
