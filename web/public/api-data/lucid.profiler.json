      ],
      "summary": "Aggregated timing summary for a single op name across many calls.",
      "extended": "Produced by `Profiler.key_averages`, which buckets the recorded\n`OpEvent` list by op name and exposes total time, average\ntime, call count, and cumulative FLOP estimate. This is the natural\nobject for a \"top-k by self-time\" performance report.",
      "parameters": [
        {
          "name": "name",
          "annotation": "str",
          "description": "Op name shared by all events in the summary.",
          "default": null
        },
        {
          "name": "events",
          "annotation": "list of OpEvent",
          "description": "Recorded events bucketed under `name`.",
          "default": null
        }
      ],
      "returns": null,
      "raises": [],
      "examples": [
        ">>> import lucid\n>>> with lucid.profiler.profile() as prof:\n...     for _ in range(10):\n...         y = lucid.randn(64, 64) @ lucid.randn(64, 64)\n>>> for summary in prof.key_averages()[:3]:\n...     print(summary)"
      ],
      "notes": [
        "The average is computed as\n\n$$\n\\bar{t} = \\frac{1}{N} \\sum_{i=1}^{N} t_i,\n$$\nwhere $N$ is the call count and $t_i$ is the per-call\nduration in microseconds."
      ],
      "attributes": [],
      "warns": [],
      "see_also": []
    },
