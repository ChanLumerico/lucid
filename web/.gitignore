# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Griffe generated API data is committed to keep the docs deploy fast —
# the pre-commit hook rebuilds + re-stages it whenever lucid/ source
# changes, so CI just consumes the JSON tree as a static input.

# Pagefind static search index (rebuilt on deploy)
/public/pagefind

# Build metadata (rewritten by scripts/build-meta.py on every prebuild)
/public/build-meta.json

# Generated BibTeX (rewritten from data/citations.json by build-bibtex.py)
/public/citations.bib
