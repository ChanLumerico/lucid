{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "python3 scripts/build-api-data-cached.py && python3 scripts/build-cross-links.py && python3 scripts/build-usedby.py && python3 scripts/link-citations.py && python3 scripts/build-bibtex.py && python3 scripts/build-meta.py",
    "dev": "next dev",
    "dev:fast": "SKIP_API_BUILD=1 python3 scripts/build-bibtex.py && python3 scripts/build-meta.py && next dev",
    "prebuild": "python3 scripts/build-api-data-cached.py && python3 scripts/build-cross-links.py && python3 scripts/build-usedby.py && python3 scripts/link-citations.py && python3 scripts/build-bibtex.py && python3 scripts/build-meta.py",
    "citations": "python3 scripts/link-citations.py",
    "cross-links": "python3 scripts/build-cross-links.py",
    "usedby": "python3 scripts/build-usedby.py",
    "build": "next build",
    "build:analyze": "ANALYZE=1 next build",
    "start": "next start",
    "lint": "eslint",
    "build:api": "python3 scripts/build-api-data.py",
    "build:api:module": "python3 scripts/build-api-data.py --module",
    "check:api-drift": "python3 scripts/build-api-data-cached.py --check",
    "rebaseline:api-cache": "python3 scripts/build-api-data-cached.py --write-cache",
    "validate:math": "node scripts/validate-math.mjs",
    "audit:docs": "node scripts/audit-docs.mjs"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/pretendard": "^5.2.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shikijs/rehype": "^4.0.2",
    "@tailwindcss/postcss": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.45",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/katex": "^0.16.8",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "node-html-parser": "^7.1.0",
    "typescript": "^5"
  }
}
